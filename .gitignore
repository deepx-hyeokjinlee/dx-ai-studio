logs/

# Runtime artifacts (P2-2-D): user-viewable results + internal transient
# state, consolidated per-app under these two top-level trees via
# shared/paths.py (outputs_dir/var_dir). dx_benchmark/results/ is a
# pre-existing tracked reference dataset (legacy fallback), not runtime
# output, and stays tracked.
/outputs/
/var/

# Local virtualenvs (machine-specific, ~700MB — never commit)
.venv/
.venv-help-audit/

# Generated audit output
dx_modelzoo/data/image_audit.html
tests/zoom_audit_deep.json
tests/zoom_audit_report.json

# Superpowers planning artifacts — never committed (CLAUDE.md git safety)
docs/superpowers/

# User-manual (MkDocs) build artifacts — regenerated via docs/make_html.md
docs/site/
docs/.venv-docs/

# Internal / non-shippable (agent-driven-dev output, agent working data, dev artifacts)
dx-agent-dev/
# workspace/: pre-P2-2-D dx_agent_dev state (agent-conversations/, agent-sessions/).
# New writes go to var/dx_agent_dev/{conversations,sessions}/ (see /var/ above); this
# old dir is kept ignored rather than migrated/deleted per the "don't touch existing
# result files" rule -- it holds real prior session history, not a fresh empty dir.
workspace/
.coverage
PROJECT_CONTEXT.md
HANDOFF.md
RELEASE_NOTES_MATERIAL.md

# Image-optimization audit record (dev-generated by dx_modelzoo/scripts/optimize_images.py;
# runtime-unused; embeds absolute dev worktree paths — must never ship)
dx_modelzoo/data/optimized/manifest.json

# Dev artifacts pulled into the tree (extracted archives; docs/.venv-docs is
# already covered under the MkDocs build-artifacts section above)
*.zip

# dx_stream verify run outputs (transient)
dx_stream/verification/report-*.csv
dx_stream/verification/report-*.md
dx_stream/verification/BUG-*.md
